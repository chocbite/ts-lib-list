{
  "name": "@chocbite/ts-lib-list",
  "version": "1.0.2",
  "description": "List/table creation UI library for TypeScript",
  "author": "chocolateandmilkwin",
  "license": "MIT",
  "type": "module",
  "private": false,
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "style": "./dist/style.css",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts",
      "style": "./dist/style.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --port 9977",
    "build": "tsdown src/index.ts",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run",
    "check-trials": "tsc --noEmit",
    "prepublishOnly": "npm run check-trials && npm run build",
    "upgrades": "npx npm-check-updates --target semver",
    "upgrade": "npx npm-check-updates --target semver -u && npm install"
  },
  "devDependencies": {
    "@chocbite/ts-supplement-eslint": "^1.0.0",
    "@chocbite/ts-lib-common": "^1.2.2",
    "@chocbite/ts-lib-icons": "^1.1.0",
    "@chocbite/ts-lib-context-menu": "^1.0.3",
    "@tsdown/css": "^0.21.7",
    "@vitest/browser-playwright": "^4.1.3",
    "eslint": "^10.2.0",
    "sass": "^1.99.0",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.6",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "@chocbite/ts-lib-base": "^1.4.2",
    "@chocbite/ts-lib-icons": "^1.1.0",
    "@chocbite/ts-lib-result": "^1.3.1",
    "@chocbite/ts-lib-state": "^2.1.2",
    "@chocbite/ts-lib-theme": "^1.2.1"
  }
}
